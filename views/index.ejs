<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Finance Manager</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
  <%- include('header') %>

  <div class="container mt-4">
    <% if(success && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show col-md-6 offset-md-3" role="alert">
          <%= success %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>
    <% if(error && error.length > 0) { %>
      <div class="alert alert-danger alert-dismissible fade show col-md-6 offset-md-3" role="alert">
        <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <div class="card col-md-6 offset-md-3 shadow-sm border-0 mt-3">
        <div class="card-header bg-primary text-white text-center">
            <h4>Add Spend / Income</h4>
        </div>
        <div class="card-body p-4">
            <form action="/home" method="post" id="moneyForm">

                <div class="mb-3 d-flex justify-content-center gap-4">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="type" id="typeSpend" value="spend" checked>
                        <label class="form-check-label" for="typeSpend">Spend</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="type" id="typeIncome" value="income" required>
                        <label class="form-check-label" for="typeIncome">Income</label>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="currency" class="form-label">Currency</label>
                        <select class="form-select" id="currency" name="currency" required>
                            <option value="INR">INR</option>
                            <option value="USD">USD</option>
                        </select>
                    </div>
                    <div class="col-md-8">
                        <label for="number" class="form-label">Amount</label>
                        <input type="number" class="form-control" id="number" name="ammount" min="0" placeholder="0" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="category" class="form-label">Category</label>
                    <select class="form-select" id="category" name="cat" required>
                        <option value="" disabled selected hidden>Choose Category</option>
                        <option value="Salary">Salary (Income)</option>
                        <option value="Gym">Gym</option>
                        <option value="Fuel">Fuel</option>
                        <option value="Grocery">Grocery</option>
                        <option value="recharge">Recharge</option>
                        <option value="rent">Rent</option>
                        <option value="medicine">Medicine</option>
                        <option value="travel">Travel</option>
                        <option value="others">Others</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="date" class="form-label">Date</label>
                    <input type="date" class="form-control" id="date" name="date" required>
                </div>

                <div class="mb-3">
                    <label for="mode" class="form-label">Mode of Payment</label>
                    <select class="form-select" id="mode" name="mode">
                        <option value="" disabled selected hidden>Choose Mode</option>
                        <option value="online">Online</option>
                        <option value="cash">Cash</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea class="form-control" placeholder="Add comment" id="comment" name="comment" rows="2"></textarea>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Save Transaction</button>
                </div>
            </form>
        </div>
    </div>
  </div>

  <footer class="footer bg-dark text-white text-center py-3 mt-5">
      <div class="container">
          <p class="mb-1">&copy; 2024 My CA. All rights reserved.</p>
          <nav>
              <a href="/home/privacy" class="text-white text-decoration-none me-3">Privacy Policy</a>
              <a href="/home/terms" class="text-white text-decoration-none me-3">Terms of Service</a>
              <a href="/home/contact" class="text-white text-decoration-none">Contact Us</a>
          </nav>
      </div>
  </footer>
    
  <script src="/main.js"></script>
  <script>
      document.getElementById('date').valueAsDate = new Date();
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>