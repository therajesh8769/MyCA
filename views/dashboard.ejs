<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/style.css">
    <style>
        .card { margin: 20px 0; }
        .chart-container { position: relative; height: 40vh; width: 100%; }
    </style>
</head>
<body>
    <%- include('header') %>

    <div class="container mt-4">
        <h1 class="mb-4">Dashboard</h1>

        <!-- Summary Cards -->
        <div class="row text-center mb-4">
            <div class="col-md-3">
                <div class="card text-white bg-success shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Total Income</h5>
                        <p class="card-text fs-4">₹<%= totalIncome %></p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-danger shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Total Expense</h5>
                        <p class="card-text fs-4">₹<%= totalExpense %></p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white shadow-sm <%= netBalance >= 0 ? 'bg-primary' : 'bg-warning' %>">
                    <div class="card-body">
                        <h5 class="card-title">Net Balance</h5>
                        <p class="card-text fs-4">₹<%= netBalance %></p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-white bg-info shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">Total Transactions</h5>
                        <p class="card-text fs-4"><%= count %></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Recent Transactions -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white">Recent Transactions</div>
                    <ul class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                        <% if (recent.length > 0) { %>
                            <% recent.forEach(transaction => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong><%= transaction.cat || 'Others' %></strong>
                                        <br>
                                        <small class="text-muted"><%= new Date(transaction.date).toLocaleDateString() %></small>
                                    </div>
                                    <span class="badge <%= transaction.type === 'income' ? 'bg-success' : 'bg-danger' %> rounded-pill">
                                        <%= transaction.type === 'income' ? '+' : '-' %>₹<%= transaction.ammount %>
                                    </span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="list-group-item text-muted">No recent transactions found.</li>
                        <% } %>
                    </ul>
                </div>
            </div>

            <!-- Expense Category Breakdown -->
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white">Expense by Category</div>
                    <div class="card-body d-flex justify-content-center align-items-center">
                        <% if (category.length > 0) { %>
                            <div class="chart-container">
                                <canvas id="categoryChart"></canvas>
                            </div>
                        <% } else { %>
                            <p class="text-muted text-center w-100">No expense data available for chart.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Chart Configuration -->
    <% if (category.length > 0) { %>
    <script>
        const ctx = document.getElementById('categoryChart').getContext('2d');
        const categoryLabels = <%- JSON.stringify(category.map(item => item._id || 'Others')) %>;
        const categoryData = <%- JSON.stringify(category.map(item => item.total)) %>;

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: categoryLabels,
                datasets: [{
                    data: categoryData,
                    backgroundColor: [
                        '#ff6384', '#36a2eb', '#ffce56', '#4bc0c0', '#9966ff', '#ff9f40', '#c9cbcf'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right'
                    }
                }
            }
        });
    </script>
    <% } %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>