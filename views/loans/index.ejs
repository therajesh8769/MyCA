<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loans Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('../header') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Loans Dashboard</h2>
            <a href="/loans/new" class="btn btn-primary">Create New Request</a>
        </div>

        <% if(success && success.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>
        <% if(error && error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="row">
            <!-- Received Requests (Requires Action) -->
            <div class="col-md-6 mb-4">
                <div class="card border-warning">
                    <div class="card-header bg-warning text-dark">Pending Requests (Action Required)</div>
                    <ul class="list-group list-group-flush">
                        <% if(receivedRequests.length === 0) { %>
                            <li class="list-group-item text-muted">No pending requests.</li>
                        <% } else { %>
                            <% receivedRequests.forEach(req => { %>
                                <li class="list-group-item">
                                    <strong><%= req.type === 'borrow' ? 'Borrow Request' : 'Lend Request' %></strong><br>
                                    From: <%= req.type === 'borrow' ? req.borrowerMobile : req.lenderMobile %><br>
                                    Amount: <%= req.amount %><br>
                                    Due: <%= new Date(req.dueDate).toLocaleDateString() %><br>
                                    <% if (req.message) { %>
                                        Message: <em><%= req.message %></em>
                                    <% } %><br>
                                    <% if (req.message) { %>
                                        Message: <em><%= req.message %></em><br>
                                    <% } %>
                                    <div class="mt-2">
                                        <!-- Trigger Modals -->
                                        <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#acceptModal<%= req._id %>">Accept</button>
                                        <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal<%= req._id %>">Reject</button>

                                        <!-- Accept Modal -->
                                        <div class="modal fade" id="acceptModal<%= req._id %>" tabindex="-1" aria-hidden="true">
                                          <div class="modal-dialog">
                                            <div class="modal-content">
                                              <form action="/loans/<%= req._id %>/accept" method="POST">
                                                <div class="modal-header">
                                                  <h5 class="modal-title">Accept Request</h5>
                                                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body">
                                                  <div class="mb-3">
                                                    <label for="comments" class="form-label">Comments (Optional)</label>
                                                    <textarea class="form-control" name="comments" rows="2" placeholder="Add a comment..."></textarea>
                                                  </div>
                                                </div>
                                                <div class="modal-footer">
                                                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                  <button type="submit" class="btn btn-success">Confirm Accept</button>
                                                </div>
                                              </form>
                                            </div>
                                          </div>
                                        </div>

                                        <!-- Reject Modal -->
                                        <div class="modal fade" id="rejectModal<%= req._id %>" tabindex="-1" aria-hidden="true">
                                          <div class="modal-dialog">
                                            <div class="modal-content">
                                              <form action="/loans/<%= req._id %>/reject" method="POST">
                                                <div class="modal-header">
                                                  <h5 class="modal-title">Reject Request</h5>
                                                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body">
                                                  <div class="mb-3">
                                                    <label for="comments" class="form-label">Comments (Optional)</label>
                                                    <textarea class="form-control" name="comments" rows="2" placeholder="Reason for rejection..."></textarea>
                                                  </div>
                                                </div>
                                                <div class="modal-footer">
                                                  <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                  <button type="submit" class="btn btn-danger">Confirm Reject</button>
                                                </div>
                                              </form>
                                            </div>
                                          </div>
                                        </div>
                                        <!-- UPI Pay Link for Lenders accepting a borrow request -->
                                        <% if (req.type === 'borrow') { %>
                                            <%
                                            // Ideally, populate target user to get their UPI ID,
                                            // Assuming the target user is populated in borrower
                                            let rawUpiId = req.borrower && req.borrower.upiId ? req.borrower.upiId : 'placeholder@upi';
                                            let rawName = req.borrower && req.borrower.username ? req.borrower.username : 'User';
                                            let upiId = encodeURIComponent(rawUpiId);
                                            let name = encodeURIComponent(rawName);
                                            %>

                                            <button type="button" class="btn btn-sm btn-info text-white" data-bs-toggle="modal" data-bs-target="#payModal<%= req._id %>">Accept & Pay</button>

                                            <!-- Pay Modal -->
                                            <div class="modal fade" id="payModal<%= req._id %>" tabindex="-1" aria-hidden="true">
                                              <div class="modal-dialog">
                                                <div class="modal-content">
                                                  <div class="modal-header">
                                                    <h5 class="modal-title">Payment Options</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                  </div>
                                                  <div class="modal-body text-center">
                                                    <p>Scan the QR code or choose an app to pay.</p>
                                                    <% let upiUrlPending = `upi://pay?pa=${upiId}&pn=${name}&am=${req.amount}&cu=INR&tn=Loan%20Request`; %>
                                                    <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=<%= encodeURIComponent(upiUrlPending) %>" alt="UPI QR Code" class="img-fluid mb-4">

                                                    <div class="d-grid gap-2">
                                                        <a href="phonepe://pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= req.amount %>&cu=INR&tn=Loan%20Request" class="btn btn-outline-primary">Pay via PhonePe</a>
                                                        <a href="tez://upi/pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= req.amount %>&cu=INR&tn=Loan%20Request" class="btn btn-outline-danger">Pay via Google Pay</a>
                                                        <a href="paytmmp://pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= req.amount %>&cu=INR&tn=Loan%20Request" class="btn btn-outline-info">Pay via Paytm</a>
                                                        <a href="whatsapp://pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= req.amount %>&cu=INR&tn=Loan%20Request" class="btn btn-outline-success">Pay via WhatsApp</a>
                                                        <a href="<%= upiUrlPending %>" class="btn btn-primary">Other UPI Apps</a>
                                                    </div>

                                                    <form action="/loans/<%= req._id %>/accept" method="POST" class="mt-4">
                                                        <div class="mb-3 text-start">
                                                          <label for="comments" class="form-label">Add Comments (Optional) after payment</label>
                                                          <textarea class="form-control" name="comments" rows="2" placeholder="Payment completed..."></textarea>
                                                        </div>
                                                        <button type="submit" class="btn btn-success w-100">Mark as Accepted</button>
                                                    </form>
                                                  </div>
                                                </div>
                                              </div>
                                            </div>

                                        <% } %>
                                    </div>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>
            </div>

            <!-- Sent Requests (Awaiting Action) -->
            <div class="col-md-6 mb-4">
                <div class="card border-secondary">
                    <div class="card-header bg-secondary text-white">Sent Requests (Awaiting Action)</div>
                    <ul class="list-group list-group-flush">
                        <% if(sentRequests.length === 0) { %>
                            <li class="list-group-item text-muted">No sent requests pending.</li>
                        <% } else { %>
                            <% sentRequests.forEach(req => { %>
                                <li class="list-group-item">
                                    <strong><%= req.type === 'borrow' ? 'Borrowing' : 'Lending' %></strong><br>
                                    To Mobile: <%= req.type === 'borrow' ? req.lenderMobile : req.borrowerMobile %><br>
                                    Amount: <%= req.amount %><br>
                                    Due: <%= new Date(req.dueDate).toLocaleDateString() %>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>
            </div>
        </div>


        <div class="row">
            <!-- Rejected Requests -->
            <div class="col-md-12 mb-4">
                <div class="card border-dark">
                    <div class="card-header bg-dark text-white">Rejected Requests</div>
                    <ul class="list-group list-group-flush">
                        <% if(typeof rejectedRequests !== 'undefined' && rejectedRequests.length > 0) { %>
                            <% rejectedRequests.forEach(req => { %>
                                <li class="list-group-item">
                                    <strong><%= req.type === 'borrow' ? 'Borrowing' : 'Lending' %></strong><br>
                                    To Mobile: <%= req.type === 'borrow' ? req.lenderMobile : req.borrowerMobile %><br>
                                    Amount: <%= req.amount %><br>
                                    <% if (req.message) { %>
                                        Message: <em><%= req.message %></em><br>
                                    <% } %>
                                    Status: <span class="badge bg-danger">Rejected</span><br>
                                    <% if (req.comments) { %>
                                        Rejection Reason: <strong><%= req.comments %></strong>
                                    <% } %>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="list-group-item text-muted">No rejected requests.</li>
                        <% } %>
                    </ul>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Active Borrowings -->
            <div class="col-md-6 mb-4">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">Active Borrowings (To Pay)</div>
                    <ul class="list-group list-group-flush">
                        <% if(activeBorrowings.length === 0) { %>
                            <li class="list-group-item text-muted">No active borrowings.</li>
                        <% } else { %>
                            <% activeBorrowings.forEach(loan => { %>
                                <li class="list-group-item">
                                    Lender Mobile: <%= loan.lenderMobile %><br>
                                    Amount: <%= loan.amount %><br>
                                    Due: <%= new Date(loan.dueDate).toLocaleDateString() %><br>
                                    Interest: <%= loan.category === 'with_interest' ? loan.interestRate + '% ' + loan.interestType : 'None' %><br>
                                    <% if (loan.comments) { %>
                                        Comments: <em><%= loan.comments %></em><br>
                                    <% } %>
                                    <form action="/loans/<%= loan._id %>/settle" method="POST" class="mt-2 d-inline">
                                        <button class="btn btn-sm btn-outline-danger">Mark Settled</button>
                                    </form>
                                    <%
                                    let rawUpiId = loan.lender && loan.lender.upiId ? loan.lender.upiId : 'placeholder@upi';
                                    let rawName = loan.lender && loan.lender.username ? loan.lender.username : 'Lender';
                                    let upiId = encodeURIComponent(rawUpiId);
                                    let name = encodeURIComponent(rawName);
                                    %>

                                    <button type="button" class="btn btn-sm btn-info text-white mt-2" data-bs-toggle="modal" data-bs-target="#payActiveModal<%= loan._id %>">Pay</button>

                                    <!-- Pay Active Modal -->
                                    <div class="modal fade" id="payActiveModal<%= loan._id %>" tabindex="-1" aria-hidden="true">
                                      <div class="modal-dialog">
                                        <div class="modal-content">
                                          <div class="modal-header">
                                            <h5 class="modal-title">Payment Options</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                          </div>
                                          <div class="modal-body text-center">
                                            <p>Scan the QR code or choose an app to pay.</p>
                                            <% let upiUrlActive = `upi://pay?pa=${upiId}&pn=${name}&am=${loan.amount}&cu=INR&tn=Loan%20Repayment`; %>
                                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=<%= encodeURIComponent(upiUrlActive) %>" alt="UPI QR Code" class="img-fluid mb-4">

                                            <div class="d-grid gap-2">
                                                <a href="phonepe://pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= loan.amount %>&cu=INR&tn=Loan%20Repayment" class="btn btn-outline-primary">Pay via PhonePe</a>
                                                <a href="tez://upi/pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= loan.amount %>&cu=INR&tn=Loan%20Repayment" class="btn btn-outline-danger">Pay via Google Pay</a>
                                                <a href="paytmmp://pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= loan.amount %>&cu=INR&tn=Loan%20Repayment" class="btn btn-outline-info">Pay via Paytm</a>
                                                <a href="whatsapp://pay?pa=<%= upiId %>&pn=<%= name %>&am=<%= loan.amount %>&cu=INR&tn=Loan%20Repayment" class="btn btn-outline-success">Pay via WhatsApp</a>
                                                <a href="<%= upiUrlActive %>" class="btn btn-primary">Other UPI Apps</a>
                                            </div>

                                            <form action="/loans/<%= loan._id %>/settle" method="POST" class="mt-4">
                                                <button type="submit" class="btn btn-danger w-100">Mark as Settled</button>
                                            </form>
                                          </div>
                                        </div>
                                      </div>
                                    </div>

                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>
            </div>

            <!-- Active Lendings -->
            <div class="col-md-6 mb-4">
                <div class="card border-success">
                    <div class="card-header bg-success text-white">Active Lendings (To Receive)</div>
                    <ul class="list-group list-group-flush">
                        <% if(activeLendings.length === 0) { %>
                            <li class="list-group-item text-muted">No active lendings.</li>
                        <% } else { %>
                            <% activeLendings.forEach(loan => { %>
                                <li class="list-group-item">
                                    Borrower Mobile: <%= loan.borrowerMobile %><br>
                                    Amount: <%= loan.amount %><br>
                                    Due: <%= new Date(loan.dueDate).toLocaleDateString() %><br>
                                    Interest: <%= loan.category === 'with_interest' ? loan.interestRate + '% ' + loan.interestType : 'None' %><br>
                                    <% if (loan.comments) { %>
                                        Comments: <em><%= loan.comments %></em><br>
                                    <% } %>
                                    <form action="/loans/<%= loan._id %>/settle" method="POST" class="mt-2 d-inline">
                                        <button class="btn btn-sm btn-outline-success">Mark Settled</button>
                                    </form>
                                </li>
                            <% }) %>
                        <% } %>
                    </ul>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>