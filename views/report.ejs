<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Full Report</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('header') %>

    <div class="container mt-4">
        <h3 class="mb-4">Full Transaction Report</h3>
        <div class="table-responsive shadow-sm">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-primary">
                    <tr>
                        <th>S.No.</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th>Mode</th>
                        <th>Comment</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (allTrans.length === 0) { %>
                        <tr>
                            <td colspan="7" class="text-center text-muted">No transactions found.</td>
                        </tr>
                    <% } else { %>
                        <% allTrans.forEach((entry, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td>
                                    <span class="badge <%= entry.type === 'income' ? 'bg-success' : 'bg-danger' %>">
                                        <%= entry.type.toUpperCase() %>
                                    </span>
                                </td>
                                <td class="<%= entry.type === 'income' ? 'text-success' : 'text-danger' %> fw-bold">
                                    <%= entry.type === 'income' ? '+' : '-' %>₹<%= entry.ammount %>
                                </td>
                                <td><%= entry.cat %></td>
                                <td><%= new Date(entry.date).toLocaleDateString() %></td>
                                <td><span class="badge bg-secondary"><%= entry.mode %></span></td>
                                <td><%= entry.comment %></td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>