<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Income Report</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body>
    <%- include('header') %>
    
    <div class="container mt-4">
        <h3 class="mb-4 text-success">Income Report</h3>
        <div class="table-responsive shadow-sm">
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-success">
                    <tr>
                        <th>S.No.</th>
                        <th>Amount</th>
                        <th>Category</th>
                        <th>Date</th>
                        <th>Mode</th>
                        <th>Comment</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (result.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted">No income records found.</td>
                        </tr>
                    <% } else { %>
                        <% result.forEach((entry, index) => { %>
                            <tr>
                                <td><%= index + 1 %></td>
                                <td class="text-success fw-bold">+₹<%= entry.ammount %></td>
                                <td><%= entry.cat %></td>
                                <td><%= new Date(entry.date).toLocaleDateString() %></td>
                                <td><span class="badge bg-secondary"><%= entry.mode %></span></td>
                                <td><%= entry.comment %></td>
                            </tr>
                        <% }); %>
                    <% } %>
                </tbody>
                <tfoot class="table-light fw-bold">
                    <tr>
                        <td colspan="5" class="text-end">Total Income:</td>
                        <td class="text-success">
                            <%
                            let totalIncome = 0;
                            result.forEach(entry => { totalIncome += entry.ammount; });
                            %>
                            ₹<%= totalIncome %>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>