<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%-include('header')%>
    
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-primary text-white text-center">
                        <h4><%= currUser.username %>'s Profile</h4>
                    </div>
                    <div class="card-body p-4">
                        <div class="row mb-3">
                            <div class="col-sm-4 text-muted">Email</div>
                            <div class="col-sm-8"><%= currUser.email %></div>
                        </div>
                        <hr>
                        <div class="row mb-3">
                            <div class="col-sm-4 text-muted">Mobile Number</div>
                            <div class="col-sm-8"><%= currUser.mobileNo || 'Not Set' %></div>
                        </div>
                        <hr>
                        <div class="row mb-3">
                            <div class="col-sm-4 text-muted">UPI ID</div>
                            <div class="col-sm-8"><%= currUser.upiId || 'Not Set' %></div>
                        </div>
                        <hr>
                        <div class="row mb-3">
                            <div class="col-sm-4 text-muted">Default Interest Rate (%)</div>
                            <div class="col-sm-8"><%= currUser.defaultInterestRate || '0' %>%</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                            <a href="/home/dashboard" class="btn btn-outline-primary">Dashboard</a>
                            <a href="/home/income" class="btn btn-outline-success">Income History</a>
                            <a href="/home/expense" class="btn btn-outline-danger">Expenses History</a>
                            <a href="/home/report" class="btn btn-outline-secondary">Full Report</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>

